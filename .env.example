# Frontend (Vite) — copy to .env.local and fill from Firebase console
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Google login of the original owner — on first login this account adopts the legacy 'me' portfolio.
# Must match the email in firestore.rules isAdmin(). Leave blank to disable the one-time migration.
VITE_ADMIN_EMAIL=

# Cloud Functions secrets — set via `firebase functions:secrets:set` (see functions/.env for local)
# ANTHROPIC_API_KEY=        # Phase 4 — explanation engine
# RESEND_API_KEY=           # Phase 6 — digest email
# TELEGRAM_BOT_TOKEN=       # Phase 5 — push
# TELEGRAM_CHAT_ID=         # Phase 5 — your personal chat id (single-user MVP)
