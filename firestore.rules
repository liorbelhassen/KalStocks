rules_version = '2';

// Firestore rules for the KalStocks project (its own dedicated Firebase project).
// Cloud Functions use the Admin SDK and bypass these rules.
service cloud.firestore {
  match /databases/{database}/documents {

    // Market data is written only by backend functions (admin), read is public/non-sensitive.
    match /snapshots/{doc}   { allow read: if true; allow write: if false; }
    match /events/{doc}      { allow read: if true; allow write: if false; }
    match /explanations/{doc}{ allow read: if true; allow write: if false; }
    match /briefs/{doc}      { allow read: if true; allow write: if false; }
    match /alerts_sent/{doc} { allow read: if false; allow write: if false; }
    match /usage/{doc}       { allow read: if false; allow write: if false; }

    // Per-user watchlist. TODO Phase 2/5: lock to request.auth.uid == userId once Auth is wired.
    match /watchlist/{doc} {
      allow read, write: if true;
    }
  }
}
